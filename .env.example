# RAG Document Q&A - Environment Variables
# Copy to .env and fill in your values

# Required for /query/ answers (get a free key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings (defaults work without changes)
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# Vector store - leave empty for in-memory Qdrant (ephemeral on restart)
# For persistent storage, use Qdrant Cloud (https://cloud.qdrant.io)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_documents

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_TOP_N_RERANK=20

# Set false on free-tier / low-memory hosts (Render 512MB)
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Upload limits (note: API route currently hardcodes 20MB)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20